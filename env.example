# =============================================================================
# AP Securitas -- Intelligent Incident Logger  |  .env template
# Copy to .env and fill in your keys
# =============================================================================

# ── LLM Provider (pick ONE) ──────────────────────────────────────────────────
# Options: groq | openai | huggingface
LLM_PROVIDER=groq

# Optional: if primary key is missing, auto-fall back to this provider
# FALLBACK_LLM_PROVIDER=openai

# Optional: override default model for the active provider
# Groq defaults:        llama-3.3-70b-versatile
# OpenAI defaults:      gpt-4o-mini
# HuggingFace defaults: meta-llama/Meta-Llama-3.1-8B-Instruct
# LLM_MODEL=llama-3.1-8b-instant


# ── API Keys (only the active provider's key is required) ────────────────────

# Groq -- FREE at console.groq.com
GROQ_API_KEY=gsk_your_groq_key_here

# OpenAI -- platform.openai.com/api-keys
# OPENAI_API_KEY=sk-your-openai-key-here

# Hugging Face -- huggingface.co/settings/tokens  (free; Student Pack extended)
# HUGGINGFACE_API_KEY=hf_your_token_here


# ── Embeddings ────────────────────────────────────────────────────────────────
# Options: local | openai
# local  = all-MiniLM-L6-v2 via sentence-transformers  (free, CPU, no key needed)
# openai = text-embedding-3-small                       (best quality, needs key)
EMBEDDING_MODE=local

# Only needed when EMBEDDING_MODE=openai:
# OPENAI_API_KEY=sk-your-openai-key-here


# ── FastAPI auth ──────────────────────────────────────────────────────────────
# Demo/dev: skip API key checks entirely
DISABLE_AUTH_FOR_DEMO=true

# Production: set a secret key and pass X-API-Key header in requests
# DISABLE_AUTH_FOR_DEMO=false
# APP_API_KEY=your-secret-key-here


# =============================================================================
# ZERO-COST DEV CONFIG  (copy-paste this block into your .env):
#   LLM_PROVIDER=groq
#   GROQ_API_KEY=gsk_...
#   EMBEDDING_MODE=local
#   DISABLE_AUTH_FOR_DEMO=true
#
# PRODUCTION CONFIG:
#   LLM_PROVIDER=openai
#   OPENAI_API_KEY=sk-...
#   FALLBACK_LLM_PROVIDER=groq
#   GROQ_API_KEY=gsk_...
#   EMBEDDING_MODE=openai
#   DISABLE_AUTH_FOR_DEMO=false
#   APP_API_KEY=your-secret-key
# =============================================================================
