# ── Copy this file to .env and fill in your key ──────────────────────────────
# Used by: src/agent.py, src/rag_pipeline.py, backend/main.py, frontend/app.py

OPENAI_API_KEY=sk-your-openai-api-key-here

# Embedding mode: "openai" (default, best quality) or "local" (free, no API cost)
# local mode requires: pip install sentence-transformers
# EMBEDDING_MODE=local

# Optional: Override default LLM model (default = gpt-4o-mini)
# LLM_MODEL=gpt-4o-mini
