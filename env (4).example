# ============================================================
# AP Securitas -- Intelligent Incident Logger  .env template
# Copy this file to .env and fill in your values
# ============================================================

# -- LLM Provider (default: groq = FREE) ------------------------------------
# Options: groq | openai
LLM_PROVIDER=groq

# Get free Groq key at: console.groq.com -> API Keys
GROQ_API_KEY=gsk_your_groq_key_here

# Only needed if LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-your-openai-key-here

# Optional: override the default model for your chosen provider
# Groq defaults:   llama-3.3-70b-versatile
# OpenAI defaults: gpt-4o-mini
# LLM_MODEL=llama-3.1-8b-instant

# -- Embedding Mode (default: openai) ----------------------------------------
# Options: openai | local
# local = free, uses all-MiniLM-L6-v2 (requires: pip install sentence-transformers)
EMBEDDING_MODE=local

# Only needed if EMBEDDING_MODE=openai
# OPENAI_API_KEY=sk-your-openai-key-here

# ============================================================
# Zero-cost config (Groq LLM + local embeddings):
#   LLM_PROVIDER=groq
#   GROQ_API_KEY=gsk_...
#   EMBEDDING_MODE=local
# ============================================================
